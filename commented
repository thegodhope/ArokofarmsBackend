const Subscription = require('../models/Subscription');

exports.createSubscription = async (req, res) => {
  try {
    // Files are handled by multer and available in req.files
    const { idFile, passportPhoto, receiptFile } = req.files|| {} ;

    const subscriptionData = {
      personalInfo: JSON.parse(req.body.personalInfo),
      nextOfKin: JSON.parse(req.body.nextOfKin),
      identification: {
        ...JSON.parse(req.body.identification),
        idFile: idFile ? idFile[0].path : null,
        passportPhoto: passportPhoto ? passportPhoto[0].path : null,
      },
      subscriptionDetails: JSON.parse(req.body.subscriptionDetails),
      payment: {
        ...JSON.parse(req.body.payment),
        receiptFile: receiptFile ? receiptFile[0].path : null,
      }
    };

    const newSubscription = new Subscription(subscriptionData);
    await newSubscription.save();

    res.status(201).json({ message: "Subscription submitted successfully!", data: newSubscription });
  } catch (error) {
    res.status(500).json({ message: "Server Error", error: error.message });
  }
};







